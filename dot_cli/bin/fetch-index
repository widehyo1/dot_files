#!/home/widehyo/env/local/.venv/bin/python

import os
import json
import asyncio
import aiohttp
import argparse
from functools import partial

# -------------------------
# CLI
# -------------------------
def parse_args():
    p = argparse.ArgumentParser(description="Elasticsearch/OpenSearch index fetcher")

    p.add_argument("--es-url", required=True, help="ES endpoint")
    p.add_argument("--index", required=True, help="Index name")

    p.add_argument("-o", "--out-dir", default=None, help="Output directory")
    p.add_argument("-s", "--slices", type=int, default=1, help="Slice parallelism")
    p.add_argument("-b", "--bulk-size", type=int, default=1000, help="Batch size")
    p.add_argument("--scroll", default="1m", help="Scroll duration")

    p.add_argument("--concurrency", type=int, default=4, help="HTTP concurrency")
    p.add_argument("--timeout", type=int, default=30)

    p.add_argument("--gzip", action="store_true", help="Enable gzip")
    p.add_argument("--pretty-log", action="store_true")

    return p.parse_args()


# -------------------------
# blocking write
# -------------------------
def write_bulk(file_path, hits, index):
    lines = []
    for h in hits:
        lines.append(json.dumps({"index": {"_index": index, "_id": h["_id"]}}))
        lines.append(json.dumps(h["_source"], ensure_ascii=False))

    with open(file_path, "w", buffering=1024 * 1024) as f:
        f.write("\n".join(lines) + "\n")


# -------------------------
# worker
# -------------------------
async def fetch_slice(args, slice_id, session, sem, loop):
    file_idx = 0
    total = 0

    out_dir = args.out_dir or f"{args.index}_dump"
    os.makedirs(out_dir, exist_ok=True)

    # build query (conditionally add slice)
    query = {
        "size": args.bulk_size,
        "query": {"match_all": {}}
    }

    if args.slices > 1:
        query["slice"] = {"id": slice_id, "max": args.slices}

    # initial search
    async with sem:
        async with session.post(
            f"{args.es_url}/{args.index}/_search",
            params={"scroll": args.scroll},
            json=query,
        ) as resp:
            if resp.status != 200:
                text = await resp.text()
                print(f"[HTTP ERROR][slice {slice_id}] {resp.status} {text}")
                return

            data = await resp.json()

    if "_scroll_id" not in data:
        print(f"[ERROR][slice {slice_id}] no _scroll_id in response")
        print(data)
        return

    scroll_id = data["_scroll_id"]
    hits = data.get("hits", {}).get("hits", [])

    while hits:
        file_path = os.path.join(
            out_dir,
            f"bulk_s{slice_id}_{file_idx:05d}.jsonl"
        )

        if args.pretty_log:
            print(f"[slice {slice_id}] writing {file_path} ({len(hits)} docs)")

        await loop.run_in_executor(
            None,
            partial(write_bulk, file_path, hits, args.index)
        )

        total += len(hits)
        file_idx += 1

        # scroll
        async with sem:
            async with session.post(
                f"{args.es_url}/_search/scroll",
                json={
                    "scroll": args.scroll,
                    "scroll_id": scroll_id
                },
            ) as resp:
                if resp.status != 200:
                    text = await resp.text()
                    print(f"[HTTP ERROR][slice {slice_id}] {resp.status} {text}")
                    break

                data = await resp.json()

        if "_scroll_id" not in data:
            print(f"[ERROR][slice {slice_id}] scroll failed")
            print(data)
            break

        scroll_id = data["_scroll_id"]
        hits = data.get("hits", {}).get("hits", [])

    print(f"[slice {slice_id}] done total={total}")


# -------------------------
# main
# -------------------------
async def main():
    args = parse_args()

    timeout = aiohttp.ClientTimeout(total=None)

    headers = {}
    if args.gzip:
        headers["Accept-Encoding"] = "gzip"

    connector = aiohttp.TCPConnector(
        limit=args.concurrency,
        ttl_dns_cache=300,
        keepalive_timeout=60
    )

    sem = asyncio.Semaphore(args.concurrency)
    loop = asyncio.get_running_loop()

    async with aiohttp.ClientSession(
        connector=connector,
        timeout=timeout,
        headers=headers
    ) as session:

        tasks = [
            fetch_slice(args, i, session, sem, loop)
            for i in range(args.slices)
        ]

        await asyncio.gather(*tasks)

    print("[INFO] completed")


if __name__ == "__main__":
    asyncio.run(main())
