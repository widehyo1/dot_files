#!/bin/bash
# ===== SQLITE DISK DASHBOARD =====

recorddf 1>/dev/null

DB="$HOME/machine.db"
TODAY=$(date +%F)

ROWS=$(sqlite3 "$DB" "
SELECT size, used, pcent,
case
when source = 'C:\\' then
    'C Drive'
when source = 'D:\\' then
    'D Drive'
end as source
FROM df
WHERE date = '$TODAY'
AND source in ('C:\\', 'D:\\');
")

cat <<< $ROWS | while IFS='|' read -r TOTAL USED PERCENT SOURCE; do
  PERCENT=$(tr -d '%' <<< $PERCENT)
  BAR_WIDTH=40
  FILLED=$((PERCENT * BAR_WIDTH / 100))
  EMPTY=$((BAR_WIDTH - FILLED))

  BAR=$(printf "%0.s#" $(seq 1 $FILLED))
  SPACE=$(printf "%0.s-" $(seq 1 $EMPTY))

  echo ""
  echo "===== DISK DASHBOARD ====="
  echo "$SOURCE Usage ($TODAY)"
  printf "[%s%s] %s%%\n" "$BAR" "$SPACE" "$PERCENT"
  printf "Used: %.1fGB / %.1fGB\n" \
    "$(echo "$USED / 1024 / 1024" | bc -l)" \
    "$(echo "$TOTAL / 1024 / 1024" | bc -l)"
  echo ""
done

