#!/home/widehyo/env/local/.venv/bin/python
"""
CSV → Oracle INSERT

사용법:
  python csv_to_oracle.py <csv_file> [table_name] [--rc rc.oracle]

인자:
  csv_file          삽입할 CSV 파일 경로 (필수)
  table_name        대상 테이블명 (생략 시 CSV 파일명 기준, 예: sc_apply.csv → SC_APPLY)
  --table           대상 테이블명 (positional 인자보다 우선)
  --rc              Oracle 접속 정보 파일 (기본값: rc.oracle)
  --batch           배치 크기 (기본값: 1000)

rc 파일 형식:
  export ORA_USERNAME=...
  export ORA_PASSWORD=...
  export ORA_HOST=...
  export ORA_PORT=...
  export ORA_SERVICE_NAME=...
"""

import argparse
import csv
import re
import sys
from pathlib import Path

import oracledb


def load_rc(path: Path) -> dict:
    env = {}
    with open(path) as f:
        for line in f:
            m = re.match(r'^\s*export\s+(\w+)=(.+)$', line.strip())
            if m:
                env[m.group(1)] = m.group(2)
    required = {"ORA_USERNAME", "ORA_PASSWORD", "ORA_HOST", "ORA_PORT", "ORA_SERVICE_NAME"}
    missing = required - env.keys()
    if missing:
        raise ValueError(f"rc 파일에 누락된 항목: {', '.join(sorted(missing))}")
    return env


def to_value(v: str):
    return None if v == "" else v


def main():
    parser = argparse.ArgumentParser(
        description="CSV 파일을 Oracle 테이블에 INSERT합니다.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("csv_file", help="삽입할 CSV 파일 경로")
    parser.add_argument(
        "table_name",
        nargs="?",
        help="대상 테이블명 (생략 시 CSV 파일명 사용, 대문자 변환)",
    )
    parser.add_argument(
        "--table",
        metavar="TABLE_NAME",
        help="대상 테이블명 (positional 인자보다 우선)",
    )
    parser.add_argument(
        "--rc",
        default="rc.oracle",
        metavar="RC_FILE",
        help="Oracle 접속 정보 파일 (기본값: rc.oracle)",
    )
    parser.add_argument(
        "--batch",
        type=int,
        default=1000,
        metavar="N",
        help="배치 크기 (기본값: 1000)",
    )
    args = parser.parse_args()

    csv_path = Path(args.csv_file)
    if not csv_path.exists():
        sys.exit(f"오류: CSV 파일을 찾을 수 없습니다 → {csv_path}")

    rc_path = Path(args.rc)
    if not rc_path.exists():
        sys.exit(f"오류: rc 파일을 찾을 수 없습니다 → {rc_path}")

    table = (args.table or args.table_name or csv_path.stem).upper()

    # ── 접속 정보 로드 ────────────────────────────────────────────────────────
    try:
        rc = load_rc(rc_path)
    except (OSError, ValueError) as e:
        sys.exit(f"rc 파일 읽기 실패: {e}")

    dsn = oracledb.makedsn(
        host=rc["ORA_HOST"],
        port=int(rc["ORA_PORT"]),
        service_name=rc["ORA_SERVICE_NAME"],
    )

    # ── CSV 읽기 ──────────────────────────────────────────────────────────────
    print(f"CSV 읽는 중: {csv_path}")
    with open(csv_path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        columns = reader.fieldnames
        if not columns:
            sys.exit("오류: CSV 헤더를 읽을 수 없습니다.")
        rows = list(reader)

    print(f"행 수: {len(rows):,}  |  열 수: {len(columns)}  |  테이블: {table}")

    if not rows:
        print("삽입할 데이터가 없습니다.")
        return

    # ── INSERT SQL ────────────────────────────────────────────────────────────
    col_list  = ", ".join(columns)
    bind_list = ", ".join(f":{i + 1}" for i in range(len(columns)))
    sql = f"INSERT INTO {table} ({col_list}) VALUES ({bind_list})"

    # ── DB 연결 및 INSERT ─────────────────────────────────────────────────────
    print(f"Oracle 연결 중: {rc['ORA_USERNAME']}@{rc['ORA_HOST']}:{rc['ORA_PORT']}/{rc['ORA_SERVICE_NAME']}")
    try:
        conn = oracledb.connect(
            user=rc["ORA_USERNAME"],
            password=rc["ORA_PASSWORD"],
            dsn=dsn,
        )
    except oracledb.Error as e:
        sys.exit(f"연결 실패: {e}")

    try:
        conn.autocommit = False
        cur = conn.cursor()
        cur.execute("ALTER SESSION SET NLS_DATE_FORMAT = 'YYYY-MM-DD'")
        cur.execute("ALTER SESSION SET NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS'")
        total    = len(rows)
        inserted = 0

        for start in range(0, total, args.batch):
            batch = rows[start : start + args.batch]
            data  = [
                [to_value(row[col]) for col in columns]
                for row in batch
            ]
            try:
                cur.executemany(sql, data)
            except oracledb.Error as e:
                conn.rollback()
                sys.exit(f"\n오류 (행 {start}~{start + len(batch)}): {e}")

            inserted += len(batch)
            pct = inserted / total * 100
            print(f"\r  진행: {inserted:,} / {total:,} ({pct:.1f}%)", end="", flush=True)

        conn.commit()
        print(f"\n완료: {inserted:,}건 INSERT → {table}")

    finally:
        conn.close()


if __name__ == "__main__":
    main()
